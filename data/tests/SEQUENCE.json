{
  "function": "SEQUENCE",
  "cases": [
    {
      "id": "SEQUENCE_basic_vertical",
      "formula": "=SEQUENCE(5)",
      "description": "Default rows-only sequence starting at 1, step 1",
      "expected": [
        1,
        2,
        3,
        4,
        5
      ],
      "check_range": "A30:A34"
    },
    {
      "id": "SEQUENCE_rows_cols",
      "formula": "=SEQUENCE(2,3)",
      "description": "2 rows x 3 columns filled row-major from 1",
      "expected": [
        [
          1,
          2,
          3
        ],
        [
          4,
          5,
          6
        ]
      ],
      "check_range": "A30:C31"
    },
    {
      "id": "SEQUENCE_start_step",
      "formula": "=SEQUENCE(5,1,10,5)",
      "description": "Custom start=10, step=5",
      "expected": [
        10,
        15,
        20,
        25,
        30
      ],
      "check_range": "A30:A34"
    },
    {
      "id": "SEQUENCE_negative_step",
      "formula": "=SEQUENCE(3,1,5,-1)",
      "description": "Negative step counts down",
      "expected": [
        5,
        4,
        3
      ],
      "check_range": "A30:A32"
    }
  ]
}

{
  "function": "LEFT",
  "cases": [
    {
      "id": "LEFT_default_num_chars",
      "formula": "=LEFT(A1)",
      "description": "num_chars omitted defaults to 1",
      "setup_cells": {
        "A1": "Excel"
      },
      "expected": "E"
    },
    {
      "id": "LEFT_basic",
      "formula": "=LEFT(A1,3)",
      "description": "Basic extraction of the first 3 characters",
      "setup_cells": {
        "A1": "Excel"
      },
      "expected": "Exc"
    },
    {
      "id": "LEFT_num_chars_exceeds_length",
      "formula": "=LEFT(A1,100)",
      "description": "num_chars larger than the string length returns the whole string, not an error",
      "setup_cells": {
        "A1": "Excel"
      },
      "expected": "Excel"
    },
    {
      "id": "LEFT_zero_chars",
      "formula": "=LEFT(A1,0)",
      "description": "num_chars=0 returns an empty string",
      "setup_cells": {
        "A1": "Excel"
      },
      "expected": ""
    }
  ]
}

{
  "function": "LEN",
  "cases": [
    {
      "id": "LEN_basic",
      "formula": "=LEN(\"Hello\")",
      "description": "Basic character count",
      "expected": 5
    },
    {
      "id": "LEN_numeric_value_coerced",
      "formula": "=LEN(A1)",
      "description": "A numeric cell value is coerced to text before its digits are counted",
      "setup_cells": {
        "A1": 12345
      },
      "expected": 5
    },
    {
      "id": "LEN_counts_spaces",
      "formula": "=LEN(\"  Hi  \")",
      "description": "Leading and trailing spaces are counted as characters just like any other character",
      "expected": 6
    },
    {
      "id": "LEN_empty_string",
      "formula": "=LEN(\"\")",
      "description": "Empty string has length 0",
      "expected": 0
    }
  ]
}

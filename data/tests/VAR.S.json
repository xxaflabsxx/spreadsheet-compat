{
  "function": "VAR.S",
  "cases": [
    {
      "id": "VAR.S_basic_two_points",
      "formula": "=VAR.S(A1:A2)",
      "description": "Sample variance of two hand-verifiable values",
      "setup_cells": {
        "A1": 10,
        "A2": 20
      },
      "expected": 50,
      "expected_note": "Mean=15; sample variance=((10-15)^2+(20-15)^2)/(2-1)=50"
    },
    {
      "id": "VAR.S_wikipedia_dataset",
      "formula": "=VAR.S(A1:A8)",
      "description": "Sample variance on the classic {2,4,4,4,5,5,7,9} dataset; this is the square of STDEV.S_matches_STDEV_same_data's result (2.138089935299395^2)",
      "setup_cells": {
        "A1": 2,
        "A2": 4,
        "A3": 4,
        "A4": 4,
        "A5": 5,
        "A6": 5,
        "A7": 7,
        "A8": 9
      },
      "expected": 4.571428571428571,
      "expected_note": "32/7=4.571428571428571"
    },
    {
      "id": "VAR.S_negative_numbers",
      "formula": "=VAR.S(A1:A3)",
      "description": "Sample variance over negative numbers",
      "setup_cells": {
        "A1": -2,
        "A2": -4,
        "A3": -6
      },
      "expected": 4,
      "expected_note": "Mean=-4; sample variance=((-2+4)^2+(-4+4)^2+(-6+4)^2)/(3-1)=(4+0+4)/2=4"
    },
    {
      "id": "VAR.S_single_value_div0",
      "formula": "=VAR.S(A1:A1)",
      "description": "Sample variance needs n>=2 (divides by n-1); one value -> #DIV/0!",
      "setup_cells": {
        "A1": 2
      },
      "expected": "#DIV/0!"
    }
  ]
}

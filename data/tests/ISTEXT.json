{
  "function": "ISTEXT",
  "cases": [
    {
      "id": "ISTEXT_text",
      "formula": "=ISTEXT(A1)",
      "description": "A genuine text string -> TRUE",
      "setup_cells": {
        "A1": "hello"
      },
      "expected": true
    },
    {
      "id": "ISTEXT_number",
      "formula": "=ISTEXT(A1)",
      "description": "A number -> FALSE",
      "setup_cells": {
        "A1": 5
      },
      "expected": false
    },
    {
      "id": "ISTEXT_boolean",
      "formula": "=ISTEXT(TRUE)",
      "description": "A logical value is not text -> FALSE",
      "expected": false
    },
    {
      "id": "ISTEXT_blank",
      "formula": "=ISTEXT(A1)",
      "description": "A blank cell -> FALSE",
      "setup_cells": {},
      "expected": false
    }
  ]
}

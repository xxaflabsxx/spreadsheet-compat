{
  "function": "NETWORKDAYS",
  "cases": [
    {
      "id": "NETWORKDAYS_basic_week",
      "formula": "=NETWORKDAYS(DATE(2024,1,1),DATE(2024,1,5))",
      "description": "Mon Jan 1 to Fri Jan 5, 2024, no holidays -> 5 workdays",
      "expected": 5
    },
    {
      "id": "NETWORKDAYS_with_holiday",
      "formula": "=NETWORKDAYS(DATE(2024,1,1),DATE(2024,1,5),DATE(2024,1,3))",
      "description": "Same range excluding one holiday (Wed Jan 3) -> 4",
      "expected": 4
    },
    {
      "id": "NETWORKDAYS_reversed_dates",
      "formula": "=NETWORKDAYS(DATE(2024,1,5),DATE(2024,1,1))",
      "description": "start_date after end_date returns a NEGATIVE count (not an error)",
      "expected": -5
    },
    {
      "id": "NETWORKDAYS_weekend_only",
      "formula": "=NETWORKDAYS(DATE(2024,1,6),DATE(2024,1,7))",
      "description": "Sat Jan 6 to Sun Jan 7, 2024 -> 0 workdays",
      "expected": 0
    }
  ]
}

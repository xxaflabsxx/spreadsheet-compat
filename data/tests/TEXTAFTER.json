{
  "function": "TEXTAFTER",
  "cases": [
    {
      "id": "TEXTAFTER_basic",
      "formula": "=TEXTAFTER(\"a-b-c\",\"-\")",
      "description": "Text after the first delimiter occurrence",
      "expected": "b-c"
    },
    {
      "id": "TEXTAFTER_instance_num",
      "formula": "=TEXTAFTER(\"a-b-c\",\"-\",2)",
      "description": "instance_num=2 counts to the 2nd delimiter",
      "expected": "c"
    },
    {
      "id": "TEXTAFTER_negative_instance",
      "formula": "=TEXTAFTER(\"a-b-c\",\"-\",-1)",
      "description": "Negative instance_num counts delimiters from the end",
      "expected": "c",
      "expected_note": "-1 means the last delimiter; text after it is 'c'"
    },
    {
      "id": "TEXTAFTER_not_found_custom",
      "formula": "=TEXTAFTER(\"abc\",\"-\",\"none\")",
      "description": "Delimiter not present with if_not_found supplied",
      "expected": "none"
    }
  ]
}

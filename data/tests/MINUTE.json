      "description": "MINUTE applied to a bare fractional-day serial -- exactly noon has 0 minutes past the hour",
      "expected": 0
    },
    {
      "id": "MINUTE_of_time_value",
      "formula": "=MINUTE(TIME(15,45,10))",

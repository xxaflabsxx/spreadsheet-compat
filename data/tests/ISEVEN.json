{
  "function": "ISEVEN",
  "cases": [
    {
      "id": "ISEVEN_negative_even",
      "formula": "=ISEVEN(-4)",
      "description": "A negative even number -> TRUE",
      "expected": true
    },
    {
      "id": "ISEVEN_negative_odd",
      "formula": "=ISEVEN(-3)",
      "description": "A negative odd number -> FALSE (docs' own example is =ISEVEN(-1) -> FALSE)",
      "expected": false
    },
    {
      "id": "ISEVEN_noninteger_truncates",
      "formula": "=ISEVEN(2.5)",
      "description": "Non-integer input is truncated toward zero before testing, per Microsoft docs' own example: '=ISEVEN(2.5) ... The decimal portion is truncated, so 2 is tested.' -> TRUE",
      "expected": true,
      "expected_note": "Confirmed via https://support.microsoft.com/en-us/office/iseven-function-aa15929a-d77b-4fbb-92f4-2f479af55356"
    },
    {
      "id": "ISEVEN_zero",
      "formula": "=ISEVEN(0)",
      "description": "Zero is documented as even -> TRUE",
      "expected": true
    },
    {
      "id": "ISEVEN_nonnumeric_error",
      "formula": "=ISEVEN(\"a\")",
      "description": "Nonnumeric input -> #VALUE! per docs",
      "expected": "#VALUE!"
    }
  ]
}

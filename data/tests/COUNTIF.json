{
  "function": "COUNTIF",
  "cases": [
    {
      "id": "COUNTIF_basic",
      "formula": "=COUNTIF(A1:A5,\">20\")",
      "description": "Count of cells greater than 20",
      "setup_cells": {
        "A1": 10,
        "A2": 20,
        "A3": 30,
        "A4": 40,
        "A5": 50
      },
      "expected": 3
    },
    {
      "id": "COUNTIF_wildcard_text",
      "formula": "=COUNTIF(A1:A3,\"a*\")",
      "description": "Wildcard text criteria",
      "setup_cells": {
        "A1": "apple",
        "A2": "banana",
        "A3": "avocado"
      },
      "expected": 2
    },
    {
      "id": "COUNTIF_case_insensitive_text_match",
      "formula": "=COUNTIF(A1:A3,\"APPLE\")",
      "description": "Text comparisons in COUNTIF are case-insensitive",
      "setup_cells": {
        "A1": "apple",
        "A2": "Apple",
        "A3": "banana"
      },
      "expected": 2,
      "expected_note": "Both 'apple' and 'Apple' match the literal 'APPLE' criteria regardless of case"
    },
    {
      "id": "COUNTIF_criteria_from_cell_concat",
      "formula": "=COUNTIF(A1:A5,\">\"&C1)",
      "description": "Dynamic criteria built by concatenating an operator with a cell reference",
      "setup_cells": {
        "A1": 10,
        "A2": 20,
        "A3": 30,
        "A4": 40,
        "A5": 50,
        "C1": 25
      },
      "expected": 3,
      "expected_note": "Criteria becomes the text \">25\"; matches 30,40,50"
    },
    {
      "id": "COUNTIF_no_match",
      "formula": "=COUNTIF(A1:A3,\">100\")",
      "description": "No matches -> 0",
      "setup_cells": {
        "A1": 1,
        "A2": 2,
        "A3": 3
      },
      "expected": 0
    }
  ]
}

{
  "function": "LARGE",
  "cases": [
    {
      "id": "LARGE_basic",
      "formula": "=LARGE(A1:A5,2)",
      "description": "2nd largest value in the range",
      "setup_cells": {
        "A1": 5,
        "A2": 3,
        "A3": 8,
        "A4": 1,
        "A5": 9
      },
      "expected": 8
    },
    {
      "id": "LARGE_k1_equals_max",
      "formula": "=LARGE(A1:A5,1)",
      "description": "k=1 returns the same value as MAX",
      "setup_cells": {
        "A1": 5,
        "A2": 3,
        "A3": 8,
        "A4": 1,
        "A5": 9
      },
      "expected": 9
    },
    {
      "id": "LARGE_k_out_of_range",
      "formula": "=LARGE(A1:A5,6)",
      "description": "k larger than the count of values -> #NUM!",
      "setup_cells": {
        "A1": 5,
        "A2": 3,
        "A3": 8,
        "A4": 1,
        "A5": 9
      },
      "expected": "#NUM!",
      "expected_note": "Only 5 values exist; requesting the 6th-largest is out of range"
    },
    {
      "id": "LARGE_k_zero_error",
      "formula": "=LARGE(A1:A3,0)",
      "description": "k=0 is also out of the valid 1..n range -> #NUM!",
      "setup_cells": {
        "A1": 5,
        "A2": 3,
        "A3": 8
      },
      "expected": "#NUM!"
    }
  ]
}

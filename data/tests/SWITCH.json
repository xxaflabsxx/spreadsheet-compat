{
  "function": "SWITCH",
  "cases": [
    {
      "id": "SWITCH_basic_match",
      "formula": "=SWITCH(2,1,\"one\",2,\"two\",3,\"three\")",
      "description": "Matches the second value/result pair",
      "expected": "two"
    },
    {
      "id": "SWITCH_default_value",
      "formula": "=SWITCH(5,1,\"one\",2,\"two\",\"default\")",
      "description": "Trailing unpaired argument acts as the default",
      "expected": "default"
    },
    {
      "id": "SWITCH_no_match_no_default",
      "formula": "=SWITCH(5,1,\"one\",2,\"two\")",
      "description": "No match and no default -> #N/A",
      "expected": "#N/A"
    },
    {
      "id": "SWITCH_text_match",
      "formula": "=SWITCH(\"b\",\"a\",\"A\",\"b\",\"B\",\"c\",\"C\")",
      "description": "Matching on text values",
      "expected": "B"
    }
  ]
}

{
  "function": "ABS",
  "cases": [
    {
      "id": "ABS_positive_number",
      "formula": "=ABS(5)",
      "description": "Positive numbers pass through unchanged",
      "expected": 5
    },
    {
      "id": "ABS_negative_number",
      "formula": "=ABS(-5)",
      "description": "Negative numbers become positive",
      "expected": 5
    },
    {
      "id": "ABS_zero",
      "formula": "=ABS(0)",
      "description": "Zero is its own absolute value",
      "expected": 0
    },
    {
      "id": "ABS_expression_argument",
      "formula": "=ABS(3-10)",
      "description": "Argument can be any expression evaluating to a number",
      "expected": 7
    },
    {
      "id": "ABS_cell_reference_negative",
      "formula": "=ABS(A1)",
      "description": "Absolute value of a negative cell reference",
      "setup_cells": {
        "A1": -12.5
      },
      "expected": 12.5
    },
    {
      "id": "ABS_error_propagates",
      "formula": "=ABS(1/0)",
      "description": "Errors in the argument propagate through ABS unchanged rather than being suppressed",
      "expected": "#DIV/0!"
    }
  ]
}

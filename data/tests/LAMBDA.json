{
  "function": "LAMBDA",
  "cases": [
    {
      "id": "LAMBDA_basic_invoke",
      "formula": "=LAMBDA(x,x*2)(5)",
      "description": "Immediately-invoked LAMBDA with one parameter",
      "expected": 10
    },
    {
      "id": "LAMBDA_two_params",
      "formula": "=LAMBDA(x,y,x+y)(3,4)",
      "description": "LAMBDA with two parameters",
      "expected": 7
    },
    {
      "id": "LAMBDA_via_LET",
      "formula": "=LET(f,LAMBDA(x,x^2),f(4))",
      "description": "LAMBDA bound to a name via LET, then called",
      "expected": 16
    },
    {
      "id": "LAMBDA_wrong_arg_count",
      "formula": "=LAMBDA(x,y,x+y)(3)",
      "description": "Calling with fewer arguments than parameters is an error",
      "expected": "#VALUE!"
    }
  ]
}

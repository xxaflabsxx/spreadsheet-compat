{
  "function": "SMALL",
  "cases": [
    {
      "id": "SMALL_basic",
      "formula": "=SMALL(A1:A5,2)",
      "description": "2nd smallest value in the range",
      "setup_cells": {
        "A1": 5,
        "A2": 3,
        "A3": 8,
        "A4": 1,
        "A5": 9
      },
      "expected": 3
    },
    {
      "id": "SMALL_k1_equals_min",
      "formula": "=SMALL(A1:A5,1)",
      "description": "k=1 returns the same value as MIN",
      "setup_cells": {
        "A1": 5,
        "A2": 3,
        "A3": 8,
        "A4": 1,
        "A5": 9
      },
      "expected": 1
    },
    {
      "id": "SMALL_k_out_of_range",
      "formula": "=SMALL(A1:A5,6)",
      "description": "k larger than the count of values -> #NUM!",
      "setup_cells": {
        "A1": 5,
        "A2": 3,
        "A3": 8,
        "A4": 1,
        "A5": 9
      },
      "expected": "#NUM!",
      "expected_note": "Only 5 values exist; requesting the 6th-smallest is out of range"
    },
    {
      "id": "SMALL_k_zero_error",
      "formula": "=SMALL(A1:A3,0)",
      "description": "k=0 is also out of the valid 1..n range -> #NUM!",
      "setup_cells": {
        "A1": 5,
        "A2": 3,
        "A3": 8
      },
      "expected": "#NUM!"
    }
  ]
}

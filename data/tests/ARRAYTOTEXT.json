{
  "function": "ARRAYTOTEXT",
  "cases": [
    {
      "id": "ARRAYTOTEXT_default_format",
      "formula": "=ARRAYTOTEXT({1,2,3})",
      "description": "Default (concise) format joins elements with comma+space",
      "expected": "1, 2, 3"
    },
    {
      "id": "ARRAYTOTEXT_strict_format",
      "formula": "=ARRAYTOTEXT({1,2,3},1)",
      "description": "format=1 (strict) reproduces array-literal syntax with braces",
      "expected": "{1,2,3}"
    },
    {
      "id": "ARRAYTOTEXT_2d_array",
      "formula": "=ARRAYTOTEXT({1,2;3,4})",
      "description": "2-D array literal, default format",
      "expected": "1, 2, 3, 4"
    },
    {
      "id": "ARRAYTOTEXT_text_elements_strict",
      "formula": "=ARRAYTOTEXT({\"a\",\"b\"},1)",
      "description": "Strict format quotes text elements",
      "expected": "{\"a\",\"b\"}"
    }
  ]
}

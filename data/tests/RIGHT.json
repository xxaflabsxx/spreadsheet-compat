{
  "function": "RIGHT",
  "cases": [
    {
      "id": "RIGHT_default_num_chars",
      "formula": "=RIGHT(A1)",
      "description": "num_chars omitted defaults to 1",
      "setup_cells": {
        "A1": "Excel"
      },
      "expected": "l"
    },
    {
      "id": "RIGHT_basic",
      "formula": "=RIGHT(A1,3)",
      "description": "Basic extraction of the last 3 characters",
      "setup_cells": {
        "A1": "Excel"
      },
      "expected": "cel"
    },
    {
      "id": "RIGHT_num_chars_exceeds_length",
      "formula": "=RIGHT(A1,100)",
      "description": "num_chars larger than the string length returns the whole string, not an error",
      "setup_cells": {
        "A1": "Excel"
      },
      "expected": "Excel"
    },
    {
      "id": "RIGHT_zero_chars",
      "formula": "=RIGHT(A1,0)",
      "description": "num_chars=0 returns an empty string",
      "setup_cells": {
        "A1": "Excel"
      },
      "expected": ""
    }
  ]
}

{
  "function": "CONCAT",
  "cases": [
    {
      "id": "CONCAT_literals",
      "formula": "=CONCAT(\"a\",\"b\",\"c\")",
      "description": "Basic literal concatenation",
      "expected": "abc"
    },
    {
      "id": "CONCAT_range",
      "formula": "=CONCAT(A1:A3)",
      "description": "CONCAT flattens a range directly (unlike CONCATENATE, which cannot take a range)",
      "setup_cells": {
        "A1": "x",
        "A2": "y",
        "A3": "z"
      },
      "expected": "xyz"
    },
    {
      "id": "CONCAT_mixed_types",
      "formula": "=CONCAT(\"val:\",5)",
      "description": "Numbers are coerced to text without an explicit TEXT() call",
      "expected": "val:5"
    },
    {
      "id": "CONCAT_2d_range",
      "formula": "=CONCAT(A1:B2)",
      "description": "2-D range is flattened row-major",
      "setup_cells": {
        "A1": "a",
        "B1": "b",
        "A2": "c",
        "B2": "d"
      },
      "expected": "abcd"
    }
  ]
}

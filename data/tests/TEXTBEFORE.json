{
  "function": "TEXTBEFORE",
  "cases": [
    {
      "id": "TEXTBEFORE_basic",
      "formula": "=TEXTBEFORE(\"a-b-c\",\"-\")",
      "description": "Text before the first delimiter occurrence",
      "expected": "a"
    },
    {
      "id": "TEXTBEFORE_instance_num",
      "formula": "=TEXTBEFORE(\"a-b-c\",\"-\",2)",
      "description": "instance_num=2 counts to the 2nd delimiter",
      "expected": "a-b"
    },
    {
      "id": "TEXTBEFORE_not_found_default",
      "formula": "=TEXTBEFORE(\"abc\",\"-\")",
      "description": "Delimiter not present and no if_not_found -> #N/A",
      "expected": "#N/A"
    },
    {
      "id": "TEXTBEFORE_not_found_custom",
      "formula": "=TEXTBEFORE(\"abc\",\"-\",\"none\")",
      "description": "Delimiter not present with if_not_found supplied",
      "expected": "none"
    },
    {
      "id": "TEXTBEFORE_negative_instance",
      "formula": "=TEXTBEFORE(\"a-b-c\",\"-\",-1)",
      "description": "Negative instance_num counts delimiters from the end",
      "expected": "a-b",
      "expected_note": "-1 means the last delimiter; text before it is 'a-b'"
    }
  ]
}

{
  "function": "FILTER",
  "cases": [
    {
      "id": "FILTER_basic",
      "formula": "=FILTER(A1:A5,B1:B5>2)",
      "description": "Spill the subset of A1:A5 where the paired B value is >2",
      "setup_cells": {
        "A1": "a",
        "A2": "b",
        "A3": "c",
        "A4": "d",
        "A5": "e",
        "B1": 1,
        "B2": 2,
        "B3": 3,
        "B4": 4,
        "B5": 5
      },
      "expected": [
        "c",
        "d",
        "e"
      ],
      "check_range": "A30:A32"
    },
    {
      "id": "FILTER_all_false_with_default",
      "formula": "=FILTER(A1:A3,B1:B3>100,\"none\")",
      "description": "if_empty argument is returned when no rows match",
      "setup_cells": {
        "A1": 1,
        "A2": 2,
        "A3": 3,
        "B1": 1,
        "B2": 2,
        "B3": 3
      },
      "expected": "none"
    },
    {
      "id": "FILTER_all_false_no_default",
      "formula": "=FILTER(A1:A3,B1:B3>100)",
      "description": "No if_empty and no matches raises #CALC!",
      "setup_cells": {
        "A1": 1,
        "A2": 2,
        "A3": 3,
        "B1": 1,
        "B2": 2,
        "B3": 3
      },
      "expected": "#CALC!"
    },
    {
      "id": "FILTER_2d_by_column_condition",
      "formula": "=FILTER(A1:B3,A1:A3>1)",
      "description": "Filtering a 2-column range by a condition on the first column",
      "setup_cells": {
        "A1": 1,
        "A2": 2,
        "A3": 3,
        "B1": "x",
        "B2": "y",
        "B3": "z"
      },
      "expected": [
        [
          2,
          "y"
        ],
        [
          3,
          "z"
        ]
      ],
      "check_range": "A30:B31"
    },
    {
      "id": "FILTER_inline_array_literal",
      "formula": "=FILTER({1,2,3,4},{1,0,1,0})",
      "description": "Filtering an inline array literal by an inline boolean/number mask",
      "expected": [
        1,
        3
      ],
      "check_range": "A30:B30"
    }
  ]
}

{
  "function": "HYPERLINK",
  "cases": [
    {
      "id": "HYPERLINK_with_friendly_name",
      "formula": "=HYPERLINK(\"https://example.com\",\"Click here\")",
      "description": "Formula result (display text) is the friendly_name when supplied",
      "expected": "Click here"
    },
    {
      "id": "HYPERLINK_without_friendly_name",
      "formula": "=HYPERLINK(\"https://example.com\")",
      "description": "With no friendly_name argument, the displayed result falls back to link_location itself",
      "expected": "https://example.com"
    },
    {
      "id": "HYPERLINK_friendly_name_numeric",
      "formula": "=HYPERLINK(\"https://example.com\",42)",
      "description": "friendly_name may be a number; the formula result is that numeric value",
      "expected": 42
    },
    {
      "id": "HYPERLINK_friendly_name_from_cell",
      "formula": "=HYPERLINK(\"https://example.com\",A1)",
      "description": "friendly_name supplied via a cell reference",
      "setup_cells": {
        "A1": "Go"
      },
      "expected": "Go"
    }
  ]
}

      "formula": "=MAXIFS(A1:A5,B1:B5,\">2\")",
      "description": "Max of A where paired B > 2",
      "setup_cells": {
        "A1": 10,
        "A2": 20,
        "A3": 30,
        "A4": 40,
        "A5": 50,
        "B1": 1,
        "B2": 2,
        "B3": 3,
        "B4": 4,
        "B5": 5
      },
      "expected": 50
    },
    {
      "id": "MAXIFS_multi_criteria",
      "formula": "=MAXIFS(A1:A5,B1:B5,\">1\",C1:C5,\"<5\")",
      "description": "Two criteria ranges ANDed together",
      "setup_cells": {
        "A1": 10,
        "A2": 20,
        "A3": 30,
        "A4": 40,
        "A5": 50,
        "B1": 1,
        "B2": 2,
        "B3": 3,
        "B4": 4,
        "B5": 5,
        "C1": 1,
        "C2": 2,
        "C3": 3,
        "C4": 9,
        "C5": 9
      },
      "expected": 30
    },
    {
      "id": "MAXIFS_no_matches",
      "formula": "=MAXIFS(A1:A3,B1:B3,\">100\")",
      "description": "No rows satisfy the criteria -> 0 (not an error)",
      "setup_cells": {
        "A1": 1,
        "A2": 2,
        "A3": 3,
        "B1": 1,
        "B2": 2,
        "B3": 3
      },
      "expected": 0
    },
    {
      "id": "MAXIFS_wildcard_text",
      "formula": "=MAXIFS(A1:A3,B1:B3,\"a*\")",
      "description": "Wildcard text criteria",
      "setup_cells": {
        "A1": 1,
        "A2": 2,
        "A3": 3,
        "B1": "apple",
        "B2": "banana",
        "B3": "avocado"
      },
      "expected": 3
    }
  ]
}

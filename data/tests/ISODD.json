{
  "function": "ISODD",
  "cases": [
    {
      "id": "ISODD_negative_odd",
      "formula": "=ISODD(-3)",
      "description": "A negative odd number -> TRUE",
      "expected": true
    },
    {
      "id": "ISODD_negative_even",
      "formula": "=ISODD(-4)",
      "description": "A negative even number -> FALSE",
      "expected": false
    },
    {
      "id": "ISODD_noninteger_truncates",
      "formula": "=ISODD(3.9)",
      "description": "Non-integer input is truncated toward zero before testing (3.9 -> 3, odd) per https://support.microsoft.com/en-us/office/isodd-function-1208a56d-4f10-4f44-a5fc-648cafd6c07a ('If number is not an integer, it is truncated.')",
      "expected": true
    },
    {
      "id": "ISODD_zero",
      "formula": "=ISODD(0)",
      "description": "Zero is even, so ISODD(0) -> FALSE",
      "expected": false
    },
    {
      "id": "ISODD_nonnumeric_error",
      "formula": "=ISODD(\"a\")",
      "description": "Nonnumeric input -> #VALUE! per docs",
      "expected": "#VALUE!"
    }
  ]
}
